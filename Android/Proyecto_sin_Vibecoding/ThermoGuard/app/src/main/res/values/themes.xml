<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ThermoGuard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/deep_ocean_accent</item>
        <item name="colorPrimaryVariant">@color/deep_ocean_secondary</item>
        <item name="colorOnPrimary">@color/deep_ocean_bg</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/deep_ocean_secondary</item>
        <item name="colorSecondaryVariant">@color/deep_ocean_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/deep_ocean_bg</item>
        <!-- Background color -->
        <item name="android:windowBackground">@color/deep_ocean_bg</item>
        <!-- Text color -->
        <item name="android:textColorPrimary">@color/deep_ocean_text</item>
    </style>
</resources>