        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/ice_blue</item>
        <item name="colorPrimaryVariant">@color/ice_blue_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorSecondaryVariant">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/dark_bg</item>
        <!-- Background color -->
        <item name="android:windowBackground">@color/dark_bg</item>
        <!-- Customize your theme here. -->
    </style>
</resources>