<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:padding="24dp">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_config"
        android:textColor="@color/text_main"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Estado de conexión -->
    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_connected"
        android:textColor="@color/status_green"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- CARD TERMÓMETRO -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTermometro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:rippleColor="#2000B4D8"
        app:layout_constraintTop_toBottomOf="@id/tvEstado"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_termometro_title"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_termometro_desc"
                android:textColor="@color/text_sub"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- CARD MODO -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardModo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:rippleColor="#20FFB703"
        app:layout_constraintTop_toBottomOf="@id/cardTermometro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_modo_title"
                android:textColor="@color/thermometer_medio"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_modo_desc"
                android:textColor="@color/text_sub"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- CARD SENSOR -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSensor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:rippleColor="#20E63946"
        app:layout_constraintTop_toBottomOf="@id/cardModo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_sensor_title"
                android:textColor="@color/status_red"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_sensor_desc"
                android:textColor="@color/text_sub"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- CARD BOTÓN -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBoton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/bg_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:rippleColor="#2000B4D8"
        app:layout_constraintTop_toBottomOf="@id/cardSensor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_alarma_title"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/card_alarma_desc"
                android:textColor="@color/text_sub"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- BOTÓN DESCONECTAR -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDesconectar"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:text="@string/btn_desconectar"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:backgroundTint="@color/status_red"
        app:cornerRadius="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
