<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:padding="24dp">

    <!-- Volver -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="@string/btn_volver_icon"
        android:textColor="@color/text_sub"
        android:textSize="14sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@android:color/transparent"
        app:rippleColor="#22FFFFFF"
        app:cornerRadius="22dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_seleccionar_modo"
        android:textColor="@color/text_main"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/subtitle_seleccionar_modo"
        android:textColor="@color/text_sub"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botones de Perfil -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBajo"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="@string/preset_bajo"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:backgroundTint="@color/thermometer_frio"
        app:cornerRadius="18dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMedio"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="@string/preset_medio"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/deep_ocean_bg"
        app:backgroundTint="@color/thermometer_medio"
        app:cornerRadius="18dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnBajo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAlto"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="@string/preset_alto"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:backgroundTint="@color/thermometer_caliente"
        app:cornerRadius="18dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnMedio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Modo actual -->
    <TextView
        android:id="@+id/tvModoActual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/modo_desconocido"
        android:textColor="@color/text_sub"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Perfil activo: BAJO" />

</androidx.constraintlayout.widget.ConstraintLayout>
