<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:padding="24dp">

    <!-- Volver -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="@string/btn_volver_icon"
        android:textColor="#90A4AE"
        android:textSize="14sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@android:color/transparent"
        app:rippleColor="#22FFFFFF"
        app:cornerRadius="22dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_seleccionar_modo"
        android:textColor="#ECEFF1"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/subtitle_seleccionar_modo"
        android:textColor="#546E7A"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botones grandes -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBajo"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="@string/preset_bajo"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0E1116"
        app:backgroundTint="#4FC3F7"
        app:cornerRadius="18dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMedio"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="@string/preset_medio"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0E1116"
        app:backgroundTint="#66BB6A"
        app:cornerRadius="18dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnBajo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAlto"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:text="@string/preset_alto"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0E1116"
        app:backgroundTint="#EF5350"
        app:cornerRadius="18dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnMedio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Modo actual -->
    <TextView
        android:id="@+id/tvModoActual"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/modo_desconocido"
        android:textColor="#90A4AE"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Modo actual: BAJO" />

</androidx.constraintlayout.widget.ConstraintLayout>
