<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1116"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp">

    <!-- Botón volver (minimalista, arriba a la izquierda) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="@string/btn_volver_icon"
        android:textColor="#90A4AE"
        android:textSize="14sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        app:backgroundTint="@android:color/transparent"
        app:rippleColor="#22FFFFFF"
        app:cornerRadius="22dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#ECEFF1"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lectura grande (sin caja, estilo limpio) -->
    <TextView
        android:id="@+id/tvTemperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/default_temp"
        android:textColor="#FFCA28"
        android:textSize="64sp"
        android:textStyle="bold"
        android:fontFeatureSettings="tnum"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="23.5°C" />

    <!-- Modo -->
    <TextView
        android:id="@+id/tvMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mode_medio"
        android:textColor="#FFCA28"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvTemperature"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Termómetro (centrado, ancho fijo) -->
    <com.example.thermoguard.ThermometerView
        android:id="@+id/thermometerView"
        android:layout_width="260dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvMode"
        app:layout_constraintBottom_toTopOf="@id/presetRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Presets minimalistas -->
    <LinearLayout
        android:id="@+id/presetRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBajo"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/preset_bajo"
            android:textColor="#ECEFF1"
            android:textSize="13sp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#2A3744"
            app:strokeWidth="1dp"
            app:rippleColor="#224FC3F7"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMedio"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:text="@string/preset_medio"
            android:textColor="#ECEFF1"
            android:textSize="13sp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#2A3744"
            app:strokeWidth="1dp"
            app:rippleColor="#2266BB6A"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlto"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="@string/preset_alto"
            android:textColor="#ECEFF1"
            android:textSize="13sp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#2A3744"
            app:strokeWidth="1dp"
            app:rippleColor="#22EF5350"
            app:cornerRadius="16dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
